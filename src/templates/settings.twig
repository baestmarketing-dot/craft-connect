{% import '_includes/forms' as forms %}

{{ forms.autosuggestField({
    label: 'Deon AI Connection-Key'|t('deon-ai-connect'),
    instructions: 'Der Key aus Deon AI → Website verknüpfen. Authentifiziert eingehende Deon-AI-Calls (Header X-Deon-Key) UND den einmaligen Verbindungsaufbau beim Speichern — Site-ID, SDK-Key und Verifizierungs-UUID werden danach automatisch von Deon AI abgeholt, kein weiteres Feld nötig.'|t('deon-ai-connect'),
    id: 'apiKey', name: 'apiKey', value: settings.apiKey, suggestEnvVars: true,
}) }}

{% if settings.siteId %}
    <div style="margin: -8px 0 24px;">
        <p style="color: #2e7d32;">✓ {{ 'Verbunden — Site-ID: {siteId}'|t('deon-ai-connect', {siteId: settings.siteId}) }}</p>
    </div>
{% elseif settings.apiKey %}
    <div style="margin: -8px 0 24px;">
        <p style="color: #b26a00;">{{ 'Noch nicht verbunden — beim Speichern wird die Verbindung automatisch aufgebaut.'|t('deon-ai-connect') }}</p>
    </div>
{% endif %}

<hr>

<h2>{{ 'Berechtigungen — was darf Deon AI ändern?'|t('deon-ai-connect') }}</h2>
<p class="light">{{ 'Deon AI zeigt 1-Klick-Fixes im Dashboard nur an, wenn die passende Berechtigung hier aktiv ist — nicht freigegebene Fixes werden dort ausgegraut. Rückgängig machen (Rollback) funktioniert unabhängig davon immer.'|t('deon-ai-connect') }}</p>

{{ forms.lightswitchField({
    label: 'Title/Meta-Description/Canonical/Schema setzen'|t('deon-ai-connect'),
    instructions: 'SEO-Overrides über /deon-ai/seo — Standardmäßig aktiv, da rein serverseitig und ohne Inhaltsänderung.'|t('deon-ai-connect'),
    id: 'allowSeoMeta', name: 'allowSeoMeta', on: settings.allowSeoMeta,
}) }}

{{ forms.lightswitchField({
    label: 'Inhalte bestehender Seiten bearbeiten'|t('deon-ai-connect'),
    instructions: 'Erlaubt Deon AI, den Body bestehender Entries zu ändern, z. B. FAQ-Blöcke einzubauen (/deon-ai/faq).'|t('deon-ai-connect'),
    id: 'allowContentEdit', name: 'allowContentEdit', on: settings.allowContentEdit,
}) }}

{{ forms.lightswitchField({
    label: 'Neue Seiten anlegen'|t('deon-ai-connect'),
    instructions: 'Erlaubt Deon AI, neue Entries anzulegen — Blog-Artikel sowie Standort-/Leistungs-/Faktenseiten (/deon-ai/entry, /deon-ai/page).'|t('deon-ai-connect'),
    id: 'allowPageCreate', name: 'allowPageCreate', on: settings.allowPageCreate,
}) }}

{{ forms.lightswitchField({
    label: 'robots.txt / llms.txt'|t('deon-ai-connect'),
    instructions: 'Erlaubt Deon AI, robots.txt und llms.txt zu lesen und zu schreiben (/deon-ai/files sowie die Verwaltung weiter unten).'|t('deon-ai-connect'),
    id: 'allowFiles', name: 'allowFiles', on: settings.allowFiles,
}) }}

{{ forms.lightswitchField({
    label: 'Bild-Uploads'|t('deon-ai-connect'),
    instructions: 'Erlaubt Deon AI, Bilder als Assets hochzuladen, z. B. für Featured Images (/deon-ai/asset).'|t('deon-ai-connect'),
    id: 'allowAssets', name: 'allowAssets', on: settings.allowAssets,
}) }}

{{ forms.lightswitchField({
    label: 'Plugin automatisch aktualisieren'|t('deon-ai-connect'),
    instructions: 'Erlaubt Deon AI, dieses Plugin bei neuen Versionen selbstständig per Composer zu aktualisieren (/deon-ai/self-update) — kein manueller Login ins Control Panel nötig. Standardmäßig aktiv, da Updates auch Sicherheitsfixes enthalten können. Schlägt ein Update auf dem Server fehl (z. B. weil Composer im Hosting nicht ausführbar ist), bleibt die installierte Version unverändert und Deon AI zeigt stattdessen eine Anleitung zum manuellen Update im Control Panel.'|t('deon-ai-connect'),
    id: 'allowSelfUpdate', name: 'allowSelfUpdate', on: settings.allowSelfUpdate,
}) }}

<hr>

{{ forms.lightswitchField({
    label: 'Deon SDK automatisch einbinden'|t('deon-ai-connect'),
    instructions: 'Injiziert das Tracking-/A-B-Script auf allen Frontend-Seiten.'|t('deon-ai-connect'),
    id: 'injectSdk', name: 'injectSdk', on: settings.injectSdk,
}) }}

<hr>

{{ forms.textField({
    label: 'Blog-Section (Handle)'|t('deon-ai-connect'),
    instructions: 'In dieser Section legt Deon AI generierte Artikel an.'|t('deon-ai-connect'),
    id: 'blogSectionHandle', name: 'blogSectionHandle', value: settings.blogSectionHandle,
}) }}

{{ forms.textField({
    label: 'Artikel-Body-Feld (Handle)'|t('deon-ai-connect'),
    instructions: 'Rich-Text-/CKEditor-Feld, in das der Artikel-HTML geschrieben wird.'|t('deon-ai-connect'),
    id: 'blogBodyFieldHandle', name: 'blogBodyFieldHandle', value: settings.blogBodyFieldHandle,
}) }}

{{ forms.textField({
    label: 'Seiten-Section (Handle)'|t('deon-ai-connect'),
    instructions: 'Section für native Seiten (Standortseiten, KI-Faktenseite), die Deon AI über /deon-ai/page anlegt. Fällt auf die Blog-Section zurück, falls hier nichts eingetragen ist.'|t('deon-ai-connect'),
    id: 'pagesSectionHandle', name: 'pagesSectionHandle', value: settings.pagesSectionHandle,
}) }}

{{ forms.textField({
    label: 'Asset-Volume (Handle)'|t('deon-ai-connect'),
    instructions: 'Volume für Bild-Uploads (Featured Images). Leer lassen, um Bild-Uploads zu deaktivieren.'|t('deon-ai-connect'),
    id: 'assetVolumeHandle', name: 'assetVolumeHandle', value: settings.assetVolumeHandle,
}) }}

{{ forms.textField({
    label: 'Featured-Image-Feld (Handle)'|t('deon-ai-connect'),
    instructions: 'Asset-Feld im Entry-Type für das Titelbild. Leer lassen, um Bild-Uploads zu deaktivieren.'|t('deon-ai-connect'),
    id: 'featuredImageFieldHandle', name: 'featuredImageFieldHandle', value: settings.featuredImageFieldHandle,
}) }}

<hr>

{{ forms.lightswitchField({
    label: 'robots.txt / llms.txt verwalten'|t('deon-ai-connect'),
    instructions: 'Deon AI liefert robots.txt und llms.txt direkt am Origin aus. Achtung: Liegt im Webroot bereits eine physische robots.txt-Datei, greift diese Einstellung nicht — der Webserver liefert die Datei aus, bevor Craft überhaupt läuft. Datei in dem Fall entfernen.'|t('deon-ai-connect'),
    id: 'manageRobotsLlms', name: 'manageRobotsLlms', on: settings.manageRobotsLlms,
}) }}
