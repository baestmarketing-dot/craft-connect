{#
  Self-contained Fallback-Artikel-Template — lebt im Plugin, nicht in der
  Site. Wird von setup-blog auf Sections gesetzt, deren eigenes Theme keine
  Entry-Variablen ausgibt (bzw. die noch gar kein Template haben). Kein
  Theme-Dependency: eigenes Minimal-CSS, kein {% extends %}. SEO-Tags
  (Canonical, Meta, JSON-LD), SDK, Footer-Links und der Section-Test-/A-B-
  Split laufen über den bestehenden Response-Patcher (Plugin::init()) und
  brauchen nur <head>/<body> — die liefert dieses Template.
#}
{% set deonPlugin = craft.app.plugins.getPlugin('deon-ai-connect') %}
{% set deonBodyHtml = deonPlugin ? deonPlugin.entryBodyHtml(entry) : '' %}
{% set deonImageUrl = deonPlugin ? deonPlugin.entryFeaturedImageUrl(entry) : '' %}
<!DOCTYPE html>
<html lang="{{ craft.app.language }}">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ entry.title }}</title>
<style>
  :root { color-scheme: light; }
  * { box-sizing: border-box; }
  body {
    margin: 0;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    color: #1a1a1a;
    background: #ffffff;
    line-height: 1.65;
  }
  .deon-article-wrap { max-width: 720px; margin: 0 auto; padding: 48px 20px 80px; }
  .deon-back-link {
    display: inline-block;
    margin-bottom: 32px;
    color: #555;
    text-decoration: none;
    font-size: 14px;
  }
  .deon-back-link:hover { text-decoration: underline; }
  .deon-article-wrap h1 { font-size: 2rem; line-height: 1.25; margin: 0 0 12px; }
  .deon-article-date { color: #767676; font-size: 14px; margin: 0 0 28px; }
  .deon-featured-image { width: 100%; height: auto; border-radius: 8px; margin-bottom: 32px; display: block; }
  .deon-article-body { font-size: 1.05rem; }
  .deon-article-body img { max-width: 100%; height: auto; border-radius: 6px; }
  .deon-article-body h2 { font-size: 1.5rem; margin-top: 2em; }
  .deon-article-body h3 { font-size: 1.25rem; margin-top: 1.75em; }
  .deon-article-body a { color: #1a56db; }
  .deon-article-body blockquote {
    margin: 1.5em 0;
    padding: 0.25em 1.25em;
    border-left: 3px solid #d0d0d0;
    color: #444;
  }
</style>
</head>
<body>
<div class="deon-article-wrap">
  <a class="deon-back-link" href="{{ siteUrl() }}">&larr; {{ 'Zur Startseite'|t('deon-ai-connect') }}</a>
  <article>
    <h1>{{ entry.title }}</h1>
    {% if entry.postDate is defined and entry.postDate %}
      <p class="deon-article-date">{{ entry.postDate|date('d.m.Y') }}</p>
    {% endif %}
    {% if deonImageUrl %}
      <img class="deon-featured-image" src="{{ deonImageUrl }}" alt="{{ entry.title }}">
    {% endif %}
    <div class="deon-article-body">
      {{ deonBodyHtml|raw }}
    </div>
  </article>
</div>
</body>
</html>
